# ── App ─────────────────────────────────────────────────
APP_NAME="Profile Page API"
ENV=development

# ── CORS ────────────────────────────────────────────────
# Comma-separated origins (parsed as JSON list by pydantic-settings)
CORS_ORIGINS=["http://localhost:5173"]

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/portfolio

# ── Admin ───────────────────────────────────────────────
ADMIN_TOKEN=change_this_secret
